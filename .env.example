# Supabase project (Settings → API → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key (sb_publishable_...). Legacy anon JWT still works via NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Secret key (sb_secret_...) or legacy service_role JWT — server-only, never NEXT_PUBLIC_.
# Required for /admin “Add user” (Auth Admin API).
SUPABASE_SECRET_KEY=your_secret_key
