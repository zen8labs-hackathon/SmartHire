# Supabase project (Settings → API → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key (sb_publishable_...). Legacy anon JWT still works via NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Secret key (sb_secret_...) or legacy service_role JWT — server-only, never NEXT_PUBLIC_.
# No longer used by /admin "Add user" (JW4T8X moved account creation off the Supabase Auth Admin
# API onto DATABASE_URL/lib/db directly), nor by JD file storage (moved onto S3, see below) —
# still read by the not-yet-rewired candidate/evaluation-template storage routes (see IN9X4Q/DB7X2K).
SUPABASE_SECRET_KEY=your_secret_key

# S3 file storage (IN9X4Q decision 3, @aws-sdk/client-s3). One shared bucket, prefixed per file
# type (jd/, cv/, evaluation/...). Credentials resolved via the AWS SDK's default provider chain —
# AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY env vars for local dev, EC2 IAM instance role in
# production — no app-specific credential vars needed.
# AWS_REGION=us-east-1
# S3_BUCKET=smart-hire-files
# Postgres URI for node-pg-migrate (npm run db:migrate / db:migrate:down / db:migrate:create)
# and the app's own lib/db/* queries. Target: AWS RDS PostgreSQL (IN9X4Q) — instance not
# provisioned yet, leave unset until it exists (or point at a local/Docker Postgres 17 for dev).
# DATABASE_URL=postgresql://USER:PASSWORD@YOUR_RDS_ENDPOINT:5432/smart_hire

# Self-built auth (JW4T8X). HMAC secret for signing/verifying access JWTs (lib/auth/jwt.ts).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Required for login/session verification to work at all; missing it fails closed (blocks access).
# AUTH_JWT_SECRET=replace_with_a_random_32+_byte_secret

# LLM provider (Next.js app). Default: vercel_gateway.
# LLM_PROVIDER=vercel_gateway
# Global model id for the selected provider.
# - vercel_gateway examples: openai/gpt-4o-mini, xai/grok-4.1-fast-reasoning
# - gemini examples: gemini-2.0-flash, gemini-1.5-pro
# LLM_MODEL=openai/gpt-4o-mini
# Optional dedicated model for JD file extraction (defaults to LLM_MODEL). Stronger models reduce hallucinations.
# LLM_JD_EXTRACT_MODEL=xai/grok-4.1-fast-reasoning
# Vercel AI Gateway API key (server only). Used for JD extraction, evaluation fill, and JD–CV match when configured.
# AI_GATEWAY_API_KEY=...
# Google AI Studio API key (server only). Required when LLM_PROVIDER=gemini.
# GOOGLE_GENERATIVE_AI_API_KEY=...
# Legacy optional model override (still honored if LLM_MODEL is unset)
# AI_GATEWAY_JD_MATCH_MODEL=openai/gpt-4o-mini
# Hybrid JD match: blend LLM score with deterministic anchor (skills + experience heuristics). 0–1, default 0.65.
# JD_MATCH_AI_WEIGHT=0.65
