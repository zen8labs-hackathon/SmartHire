DATABASE_URL=postgresql://admin:admin@localhost:5432/smart_hire
AUTH_JWT_SECRET=replace_with_a_random_32_byte_secret
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_api_key

# Azure AD (Entra ID) app registration -- "Sign in with Microsoft".
# Redirect URI must be registered EXACTLY (including path) as a Web platform
# redirect URI in the app registration. Single-tenant: only accounts in
# AZURE_AD_TENANT_ID's own Azure AD tenant can sign in -- not any Azure AD
# org ("/organizations") and not personal Microsoft accounts ("/common").
# Find the tenant id at Azure Portal -> Entra ID -> Overview -> Tenant ID.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_REDIRECT_URI=
# Only set to false for a deployment served over plain HTTP with no TLS in
# front of it (e.g. a bare cloud VM IP, no domain/reverse proxy yet) -- the
# browser silently drops Secure cookies on HTTP, which breaks login. Leave
# unset (defaults to secure in production) once real TLS is in place.
# COOKIE_SECURE=false

JD_MATCH_AI_WEIGHT=0.65

S3_BUCKET=smart-hire-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
