# Supabase project (Settings → API → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key (sb_publishable_...). Legacy anon JWT still works via NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Secret key (sb_secret_...) or legacy service_role JWT — server-only, never NEXT_PUBLIC_.
# Required for /admin “Add user” (Auth Admin API).
SUPABASE_SECRET_KEY=your_secret_key

# Postgres URI for scripts/apply-vercel-migrations.mjs (local: npm run db:migrate; Vercel: set in dashboard).
# Copy from Supabase → Settings → Database → Connection string → URI. Use port 5432 (direct).
# Example shape (replace YOUR_PROJECT_REF and password):
# SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# LLM provider (Next.js app). Default: vercel_gateway. `gemini` is reserved (not implemented yet).
# LLM_PROVIDER=vercel_gateway
# Global gateway catalog model id (OpenAI-compatible). Falls back to AI_GATEWAY_JD_MATCH_MODEL, then openai/gpt-4o-mini.
# LLM_MODEL=openai/gpt-4o-mini
# Vercel AI Gateway API key (server only). Used for JD extraction, evaluation fill, and JD–CV match when configured.
# AI_GATEWAY_API_KEY=...
# Legacy optional model override (still honored if LLM_MODEL is unset)
# AI_GATEWAY_JD_MATCH_MODEL=openai/gpt-4o-mini
# Hybrid JD match: blend LLM score with deterministic anchor (skills + experience heuristics). 0–1, default 0.65.
# JD_MATCH_AI_WEIGHT=0.65
