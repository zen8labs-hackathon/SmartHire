# Develop env for EC2 (same host as production, isolated stack).
# Copy to `.env` on the server under /opt/smarthire/app-develop (never commit `.env`).
#
#   cp .env.develop.example .env
#   nano .env
#
# Public URL (after DNS + certbot): https://smart-hire-dev.zen8labs.io
# Until DNS exists: test via SSM port-forward to localhost:3200

# --- Postgres (docker-compose.develop.yml) ---
POSTGRES_USER=smarthire
POSTGRES_PASSWORD=replace_with_a_strong_password
POSTGRES_DB=smart_hire_dev

DATABASE_URL=postgresql://smarthire:replace_with_a_strong_password@db:5432/smart_hire_dev

# --- App auth ---
AUTH_JWT_SECRET=replace_with_a_random_32_byte_secret

# Azure AD — optional. Add this redirect URI in Entra when using SSO on develop:
#   https://smart-hire-dev.zen8labs.io/api/auth/azure/callback
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_REDIRECT_URI=https://smart-hire-dev.zen8labs.io/api/auth/azure/callback

# Until HTTPS (certbot) is live, allow non-Secure cookies for SSM / HTTP testing:
COOKIE_SECURE=false

# --- AI ---
AI_GATEWAY_API_KEY=
JD_MATCH_AI_WEIGHT=0.65

# --- MinIO (isolated from production) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_with_minio_password_min_8_chars
# After DNS + HTTPS:
# MINIO_CORS_ALLOW_ORIGIN=https://smart-hire-dev.zen8labs.io
S3_BUCKET=smart-hire-dev-bucket
AWS_REGION=ap-southeast-1
# After DNS + nginx + certbot, set to the public develop URL:
AWS_ENDPOINT_URL=https://smart-hire-dev.zen8labs.io
