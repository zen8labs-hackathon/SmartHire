# Production env for EC2. Copy to `.env` on the server (never commit `.env`).
#
#   cp .env.production.example .env
#   nano .env

# --- Postgres (used by docker-compose.prod.yml) ---
POSTGRES_USER=smarthire
POSTGRES_PASSWORD=replace_with_a_strong_password
POSTGRES_DB=smart_hire

# Used by migrate/app; host `db` is the compose service name.
# docker-compose.prod.yml also overrides this to the same value so a
# laptop-style localhost URL cannot sneak into containers by accident.
DATABASE_URL=postgresql://smarthire:replace_with_a_strong_password@db:5432/smart_hire

# --- App auth ---
AUTH_JWT_SECRET=replace_with_a_random_32_byte_secret

# Azure AD (Entra ID) — optional. Leave empty to use email/password login.
# Redirect URI (only if using Microsoft SSO):
#   https://smart-hire.zen8labs.io/api/auth/azure/callback
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_REDIRECT_URI=https://smart-hire.zen8labs.io/api/auth/azure/callback

# Leave unset once nginx + certbot TLS is live (Secure cookies).
# COOKIE_SECURE=false

# --- AI ---
AI_GATEWAY_API_KEY=
JD_MATCH_AI_WEIGHT=0.65

# --- Object storage: MinIO on this EC2 (default for this stack) ---
# Browser + app both use the public URL (nginx proxies /minio/ → MinIO :9000).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_with_minio_password_min_8_chars
# Optional override (comma-separated origins). Default in compose: https://smart-hire.zen8labs.io
# MINIO_CORS_ALLOW_ORIGIN=https://smart-hire.zen8labs.io
S3_BUCKET=smart-hire-bucket
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=https://smart-hire.zen8labs.io/minio

# docker-compose.prod.yml maps MINIO_ROOT_* → AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# for the app container. You do not need a real AWS S3 bucket.

# --- Optional: real AWS S3 instead of MinIO ---
# Remove/comment MinIO services usage, unset AWS_ENDPOINT_URL, and either:
#   - attach an IAM instance profile, or
#   - set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY for a real bucket.
# S3_BUCKET=smart-hire-prod
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# (do NOT set AWS_ENDPOINT_URL for real S3)
